{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CardLens",
  "version": "0.1.1",
  "identifier": "xyz.mappuzzle.cardlens",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CardLens",
        "width": 1100,
        "height": 800,
        "minWidth": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/cardlens-api"],
    "resources": [
      "resources/onnxruntime.dll",
      "resources/app.db",
      "resources/mobileclip2_s0/vision_model.onnx",
      "resources/index/mobileclip.bin",
      "resources/index/mobileclip_cards.json",
      "resources/ocrs/text-detection.rten",
      "resources/ocrs/text-recognition.rten"
    ]
  }
}
