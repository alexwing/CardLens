# URL base de la API Rust (axum). Sin barra final.
VITE_API_URL=http://localhost:8787

# Opcional: CDN propio de imagenes de cartas (self-hosting). Si se define, la app
# construye `${VITE_IMAGE_BASE}/{card_id}.png`. Si se omite, usa la imagen remota
# del catalogo (TCGdex). Ya configurado en .env.production para los builds.
# VITE_IMAGE_BASE=https://cardlens.mappuzzle.xyz/catalog
