# Credenciales para subir el catalogo de imagenes (scripts/upload_catalog.py).
# Copia este fichero a ".env.upload" (que esta IGNORADO por git) y rellena la
# contrasena. NUNCA subas .env.upload ni la contrasena al repositorio.
#
#   copy .env.upload.example .env.upload      (Windows)
#
CARDLENS_FTP_HOST=tu.host.ftp.o.ip
CARDLENS_FTP_USER=tu-usuario-ftp
CARDLENS_FTP_PORT=21
CARDLENS_FTP_REMOTE=public_html/catalog
# CARDLENS_FTP_PASS=pon-aqui-tu-contrasena
# Descomenta solo si el servidor NO soporta FTPS (subira en texto plano):
# CARDLENS_FTP_PLAIN=1
