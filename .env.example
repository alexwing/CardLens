# =====================================================================
# PokemonCardDetector - variables de entorno
# Copia este archivo a .env y ajusta los valores si lo necesitas.
# Todos los defaults funcionan en local sin tocar nada.
# =====================================================================

# Puerto de la API publica Rust (axum)
API_PORT=8787

# Puerto del servicio ML Python (FastAPI)
ML_PORT=8001

# URL del servicio ML vista desde la API Rust
ML_SERVICE_URL=http://127.0.0.1:8001

# Ruta de la base de datos SQLite compartida (la crea la API al arrancar).
# Las rutas relativas se resuelven contra la RAIZ del repo (no contra el
# directorio desde el que arranques cada servicio).
DATABASE_PATH=./data/app.db

# Directorio raiz de datos: imagenes oficiales, fotos de usuario e indice FAISS.
# Relativo a la raiz del repo; usa una ruta absoluta si lo mueves fuera.
DATA_DIR=./data

# Proveedor de precios: "null" (sin precios, default) o "tcgdex" (consulta
# opcional a la API de TCGdex con cache local de 24 horas)
PRICE_PROVIDER=null

# URL de la API publica vista desde el cliente web (Vite)
VITE_API_URL=http://localhost:8787
